# Doxygen Configuration File
# Project Settings
PROJECT_NAME           = "RVWorld"
PROJECT_BRIEF          = "RomVault Core and UI Projects"
PROJECT_NUMBER         = "local"
OUTPUT_DIRECTORY       = "docs"
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES
OUTPUT_LANGUAGE        = English
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES
ABBREVIATE_BRIEF       = "The $name class" \
                         "The $name struct" \
                         "The $name interface" \
                         "The $name enum"

# Input Settings
INPUT                  = RomVaultCore ROMVault ROMVault.Avalonia DATReader FileScanner SharedEnum CHDlib
RECURSIVE              = YES
FILE_PATTERNS          = *.cs *.md
EXCLUDE_PATTERNS       = */obj/* */bin/* */.git/*
EXCLUDE                = docs

# Extraction Settings
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
SHOW_INCLUDE_FILES     = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_NO_PARAMDOC       = YES
WARN_LOGFILE           = "docs/doxygen-warnings.log"
QUIET                  = YES

# Build Settings
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_XML           = NO
SOURCE_BROWSER         = YES
INLINE_SOURCES         = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
REFERENCES_LINK_SOURCE = YES
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = YES
DISABLE_INDEX          = NO

# Diagram Settings
HAVE_DOT               = YES
DOT_PATH               = "C:/Program Files/Graphviz/bin"
COLLABORATION_GRAPH    = YES
GROUP_GRAPHS           = YES
UML_LOOK               = YES
UML_LIMIT_NUM_FIELDS   = 10
TEMPLATE_RELATIONS     = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
GRAPHICAL_HIERARCHY    = YES
DIRECTORY_GRAPH        = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
DOT_GRAPH_MAX_NODES    = 80
MAX_DOT_GRAPH_DEPTH    = 0
DOT_MULTI_TARGETS      = NO
GENERATE_LEGEND        = YES
DOT_CLEANUP            = YES

# C# Specifics
OPTIMIZE_OUTPUT_JAVA   = YES
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
